"testlib.toy" load

\ String helper regressions.

[ 1 2 3 ] reverse [ 3 2 1 ] == check
[] reverse [] == check
"Toy" reverse "yoT" == check
"" reverse "" == check

\ Exercise both sides of the 64-bit inline-string boundary (22 bytes).
"abcdefghijklmnopqrstuv" len 22 == check
"abcdefghijklmnopqrstuvw" len 23 == check
"abcdefghijklmnopqrstuv" "w" push-back
    "abcdefghijklmnopqrstuvw" == check
"abcdefghijklmnopqrstuvw" reverse reverse
    "abcdefghijklmnopqrstuvw" == check
"abcdefghijklmnopqrstuvw" 22 at "w" == check
'abcdefghijklmnopqrstuv name "abcdefghijklmnopqrstuv" == check
'abcdefghijklmnopqrstuvw name "abcdefghijklmnopqrstuvw" == check
"" 1000 [ "x" push-back ] times len 1000 == check
"ab" dup "c" push-back "abc" == check "ab" == check
"ab" dup "cd" concat "abcd" == check "ab" == check
"ab" dup 0 "x" set-at "xb" == check "ab" == check
[ "a" "b" "c" ] "-" join "a-b-c" == check
"  Toy\n" trim "Toy" == check
"Toy" upper "TOY" == check
"Toy" lower "toy" == check

63 >char "?" == check
"?" char-code 63 == check
0 >char char-code 0 == check
255 >char char-code 255 == check
"\x3f" "?" == check
"\x00" char-code 0 == check
"\xff" char-code 255 == check
"?" repr "\"?\"" == check
"a\n\"\\" repr "\"a\\n\\\"\\\\\"" == check
"\x00\xff" repr "\"\\x00\\xff\"" == check
1 repr "1" == check
1.0 repr "1.0" == check
[ 1 "x" ] repr "[1 \"x\"]" == check

"A" char? true == check
"" char? false == check
"ab" char? false == check
1 char? false == check

"A" letter? true == check
"z" letter? true == check
"5" letter? false == check
"5" digit? true == check
"A" digit? false == check
"A" alnum? true == check
"5" alnum? true == check
"!" alnum? false == check
" " space? true == check
"\n" space? true == check
"A" upper? true == check
"a" upper? false == check
"a" lower? true == check
"A" lower? false == check
"!" punct? true == check
"A" punct? false == check

"Az 09!" 'letter? filter "Az" == check
"Az 09!" 'digit? filter "09" == check
"Az 09!" 'alnum? filter "Az09" == check
"Az 09!" 'space? filter " " == check
"Az 09!" 'punct? filter "!" == check
