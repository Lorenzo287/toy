\ Import the separately built Raylib C package.
'main package

"../.." 'rl import-as

'background [ 245 245 245 255 rl.rgba ] def
'accent [ 230 41 55 255 rl.rgba ] def
'ink [ 80 80 80 255 rl.rgba ] def

'main [
	800 450 "Toy + raylib" rl.init-window
	60 rl.set-target-fps

	[
		rl.window-should-close? not
	] [
		rl.begin-drawing
		background rl.clear-background
		rl.mouse-x rl.mouse-y 32 accent rl.draw-circle
		"This loop is running in Toy" 20 20 24 ink rl.draw-text
		rl.end-drawing
	] while

	rl.close-window
] def
