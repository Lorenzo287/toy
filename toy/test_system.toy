"--- Testing System Utilities ---\n" printf

'check [ [ ] [ "system check failed" error ] ifelse ] def

\ Testing set-env
"TEST_VAR" "TEST_VALUE" set-env

"TEST_VAR" env? true == check
"TEST_VAR" get-env print
[ "TOY_TEST_MISSING_ENV_VAR" get-env drop false ] [ true ] try true == check

\ shell returns its output first and its exit status on top.
"cd ." shell 0 == check "" == check
"TOY_TEST_MISSING_ENV_VAR" env? false == check
"cd ." shell 0 == check "" == check

unix-time dup int? true == check 0 > true == check
local-time dup map? true == check
dup 'year get 1970 >= true == check
dup 'month get 1 >= true == check
dup 'month get 12 <= true == check
dup 'day get 1 >= true == check
dup 'hour get 0 >= true == check
dup 'minute get 0 >= true == check
dup 'second get 0 >= true == check
drop
utc-time map? true == check
cpu-time cpu-time <= true == check
monotonic-ns monotonic-ns <= true == check

"--- Done ---\n" printf
