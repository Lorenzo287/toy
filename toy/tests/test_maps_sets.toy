"testlib.toy" load

\ Map and set collection regressions.

{ 'name "Ada" 'age 36 } map? true == check
#{ "red" "green" "blue" } set? true == check
{ 'name "Ada" 'age 36 } type-of "map" == check
#{ 1 2 3 } type-of "set" == check

{ 'name "Ada" 'age 36 } len 2 == check
#{ 1 2 3 } len 3 == check
{ } empty? true == check
#{} empty? true == check

{ 'name "Ada" 'age 36 } 'name get "Ada" == check
{ 'name "Ada" 'age 36 } 'age has? true == check
{ 'name "Ada" 'age 36 } 'missing has? false == check
{ 'name "Ada" } 'name "unknown" get-or "Ada" == check
{ 'name "Ada" } 'missing "unknown" get-or "unknown" == check
0 { 'a 1 } 'a 9 get-or 1 == check 0 == check
0 { 'a 1 } 'missing 9 get-or 9 == check 0 == check

{ 'a 1 'b 2 } keys [ 'a 'b ] == check
{ 'a 1 'b 2 } values [ 1 2 ] == check
{ 'a 1 'b 2 } pairs [ [ 'a 1 ] [ 'b 2 ] ] == check

{ 'a 1 } 'b 2 assoc pairs [ [ 'a 1 ] [ 'b 2 ] ] == check
{ 'a 1 'b 2 } 'a 10 assoc 'a get 10 == check
{ 'a 1 'b 2 } 'a dissoc pairs [ [ 'b 2 ] ] == check
{ 'a 1 'b 2 } 'a 10 assoc pairs [ [ 'a 10 ] [ 'b 2 ] ] == check
{ 'a 1 'b 2 } 'a dissoc 'a 3 assoc keys [ 'b 'a ] == check
{ 'a 1 } 'missing dissoc { 'a 1 } == check

\ Shared updates preserve the original map while the result changes.
{ 'a 1 } dup 'a 2 assoc swap 'a get 1 == check 'a get 2 == check
{ 'a 1 'b 2 } dup 'a dissoc swap 'a has? true == check 'a has? false == check
{ 0 0 1 1 2 2 3 3 } dup 4 4 assoc swap 4 has? false == check 4 get 4 == check

\ Different hashable types remain distinct keys.
{ 1 "integer" "one" "string" 'one "symbol" true "boolean" } len 4 == check
{ 1 "integer" "one" "string" 'one "symbol" true "boolean" } "one" get "string" == check
{ 1 "integer" "one" "string" 'one "symbol" true "boolean" } 'one get "symbol" == check

\ Exercise entry and bucket growth well beyond the initial allocation.
{ } 1000 [ dup len dup assoc ] times
dup len 1000 == check
dup 0 get 0 == check
dup 511 get 511 == check
dup 999 get 999 == check
0 500 range [ dissoc ] each
dup len 500 == check
dup 499 has? false == check
dup 500 get 500 == check
drop

[ [ 'name "Ada" ] [ 'age 36 ] ] >map { 'name "Ada" 'age 36 } == check
[ [ [ 'a 1 ] [ 'a 2 ] ] >map ] [ "duplicate" ] try "duplicate" == check

#{ 1 2 3 } 2 has? true == check
#{ 1 2 3 } 4 has? false == check
#{ 1 2 3 } items [ 1 2 3 ] == check
#{ 1 2 } 3 insert items [ 1 2 3 ] == check
#{ 1 2 3 } 2 insert items [ 1 2 3 ] == check
#{ 1 2 3 } 2 remove items [ 1 3 ] == check
#{ 1 2 3 } 9 remove items [ 1 2 3 ] == check
#{ 1 2 3 } 2 remove 2 insert items [ 1 3 2 ] == check
[ 1 2 2 3 ] >set items [ 1 2 3 ] == check
"abca" >set items [ "a" "b" "c" ] == check

\ Shared updates preserve the original set while the result changes.
#{ 1 2 } dup 3 insert swap 3 has? false == check 3 has? true == check
#{ 1 2 3 } dup 2 remove swap 2 has? true == check 2 has? false == check
#{ 0 1 2 3 } dup 4 insert swap 4 has? false == check 4 has? true == check

\ Set algebra has deterministic insertion-order projections.
#{ 3 1 } #{ 2 1 } union items [ 3 1 2 ] == check
#{ 3 1 } #{ 2 1 } intersection items [ 1 ] == check
#{ 3 1 } #{ 2 1 } difference items [ 3 ] == check
#{ 3 1 } #{ 2 1 } symmetric-difference items [ 3 2 ] == check
#{} #{ 1 2 } union items [ 1 2 ] == check
#{ 1 2 } #{} intersection empty? true == check
#{ 1 2 } #{} difference items [ 1 2 ] == check
#{} #{ 1 2 } symmetric-difference items [ 1 2 ] == check
#{ 1 2 } #{ 1 2 } difference empty? true == check
#{ 1 2 } #{ 1 2 } symmetric-difference empty? true == check

#{ 1 2 } #{ 1 2 3 } subset? true == check
#{ 1 2 } #{ 1 2 } subset? true == check
#{} #{} subset? true == check
#{ 1 2 } #{ 1 2 3 } proper-subset? true == check
#{ 1 2 } #{ 1 2 } proper-subset? false == check
#{} #{ 1 } proper-subset? true == check
#{ 1 2 3 } #{ 1 2 } superset? true == check
#{ 1 2 } #{ 1 2 } superset? true == check
#{ 1 2 3 } #{ 1 2 } proper-superset? true == check
#{ 1 2 } #{ 1 2 } proper-superset? false == check
#{ 1 2 } #{ 3 4 } disjoint? true == check
#{ 1 2 } #{ 2 3 } disjoint? false == check
#{} #{} disjoint? true == check

\ Algebra does not mutate a shared input.
#{ 1 2 } dup #{ 2 3 } union swap items [ 1 2 ] == check items [ 1 2 3 ] == check

\ Different hashable types remain distinct set items.
[ 1 "one" 'one true ] >set len 4 == check
[ 1 "one" 'one true ] >set "one" has? true == check
[ 1 "one" 'one true ] >set 'one has? true == check

\ Exercise set entry and bucket growth, lookup, and ordered removal.
#{} 1000 [ dup len insert ] times
dup len 1000 == check
dup 0 has? true == check
dup 511 has? true == check
dup 999 has? true == check
0 500 range [ remove ] each
dup len 500 == check
dup 499 has? false == check
dup 500 has? true == check
drop

[ [ [ 1 ] ] >set ] [ "unhashable" ] try "unhashable" == check

{ 'a 1 'b 2 } { 'b 2 'a 1 } == check
#{ 1 2 3 } #{ 3 2 1 } == check
