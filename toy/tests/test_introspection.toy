"testlib.toy" load

\ Introspection words return data suitable for programmatic checks.

'twice [ dup + ] def
'twice body [ dup + ] == check
'twice see "'twice [ dup + ] def" == check
'dup doc "dup\nstack: x -- x x\nDuplicate the top stack item." == check
'printf doc "placeholders" contains? true == check
'symmetric-difference doc "left-only" contains? true == check
'proper-subset? doc "strict subset" contains? true == check
'proper-superset? doc "strict superset" contains? true == check
'twice doc "'twice [ dup + ] def" == check
":" intern word? false == check
"priority" search-words dup 'pq-push contains? true == check drop
'see search-words 'see contains? true == check
"twice" search-words 'twice contains? true == check

'type-of word? true == check
'search-words word? true == check
'read-file word? true == check
'set-env word? true == check
'unix-time word? true == check
'local-time word? true == check
'utc-time word? true == check
'cpu-time word? true == check
'monotonic-ns word? true == check
'typeof word? false == check
'apropos word? false == check
'cr word? false == check
'page word? false == check
'bye word? false == check
'time word? false == check
'clock word? false == check
words vector? true == check
words [ symbol? ] all true == check
"X" intern dup symbol? true == check name "X" == check

[ 1 2 3 ] sequence? true == check
( 1 2 3 ) sequence? true == check
"abc" sequence? true == check
'twice sequence? false == check

[ 1 2 + ] callable? true == check
( 1 2 + ) callable? false == check
'twice callable? true == check
'missing-word callable? false == check
"twice" callable? false == check

'twice word? true == check
"twice" word? false == check

10 | x | 'x var? true == check
"x" var? false == check
