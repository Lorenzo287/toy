\ Deque and priority queue regressions.

'check [ [ ] [ "deque/pqueue check failed" error ] ifelse ] def

[ 1 2 3 ] >deque deque? true == check
[ 1 2 3 ] >deque typeof "deque" == check
[ 1 2 3 ] >deque len 3 == check
[ ] >deque empty? true == check

[ 1 2 3 ] >deque items [ 1 2 3 ] == check
"abc" >deque items [ "a" "b" "c" ] == check
[ 1 2 ] >deque 0 push-front items [ 0 1 2 ] == check
[ 1 2 ] >deque 3 push-back items [ 1 2 3 ] == check
[ 1 2 3 ] >deque front 1 == check
[ 1 2 3 ] >deque back 3 == check

[ 1 2 3 ] >deque pop-front items [ 2 3 ] == swap 1 == and check
[ 1 2 3 ] >deque pop-back items [ 1 2 ] == swap 3 == and check
[ [ ] >deque pop-front ] [ "empty-deque" ] try "empty-deque" == check
[ 1 2 ] >deque [ 1 2 ] >deque == check

[ [ 10 "low" ] [ 1 "urgent" ] [ 5 "mid" ] ] >pqueue pqueue? true == check
[ [ 10 "low" ] [ 1 "urgent" ] [ 5 "mid" ] ] >pqueue typeof "pqueue" == check
[ [ 10 "low" ] [ 1 "urgent" ] [ 5 "mid" ] ] >pqueue len 3 == check
[ ] >pqueue empty? true == check

[ [ 10 "low" ] [ 1 "urgent" ] [ 5 "mid" ] ] >pqueue pqueue-peek "urgent" == check
[ [ 10 "low" ] [ 1 "urgent" ] [ 5 "mid" ] ] >pqueue pqueue-drain [ "urgent" "mid" "low" ] == check
[ [ 1 "a" ] [ 1 "b" ] [ 1 "c" ] ] >pqueue pqueue-drain [ "a" "b" "c" ] == check

[ ] >pqueue 2 "two" pqueue-push 1 "one" pqueue-push pqueue-drain [ "one" "two" ] == check
[ [ 10 "low" ] [ 1 "urgent" ] [ 5 "mid" ] ] >pqueue pqueue-pop pqueue-drain [ "mid" "low" ] == swap "urgent" == and check
[ [ ] >pqueue pqueue-pop ] [ "empty-pqueue" ] try "empty-pqueue" == check

[ [ 2 "b" ] [ 1 "a" ] ] >pqueue [ [ 1 "a" ] [ 2 "b" ] ] >pqueue == check
[ [ 1 "a" ] [ 1 "b" ] ] >pqueue [ [ 1 "b" ] [ 1 "a" ] ] >pqueue != check
[ [ [ "bad" "x" ] ] >pqueue ] [ "bad-priority" ] try "bad-priority" == check
