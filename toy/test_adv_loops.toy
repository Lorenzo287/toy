[ 10 20 30 ] |vec|

\ EACH

$vec len $vec

"\n{" printf 
[ 
	printf
	1 - 
	[ 0 != ] [ "-"printf ] if
] each 
"}\n" print

drop

\ TIMES

"{" printf 
0
$vec len
[
	$vec over at printf
	1 +
	[ $vec len != ] [ "-"printf ] if
] times
"}\n" print

drop

\ WHILE

"{" printf 
0 
[ $vec len != ]
[
	$vec over at printf
	1 +
	[ $vec len != ] [ "-"printf ] if
] while
"}\n" print

drop
