[ 10 20 30 ] |list| 

\ EACH

$list len $list

"\n{" printf 
[ 
	printf
	1 - 
	[ 0 != ] [ "-"printf ] if
] each 
"}\n" print

drop

\ TIMES

"{" printf 
0
$list len
[
	$list over geth printf
	1 +
	[ $list len != ] [ "-"printf ] if
] times
"}\n" print

drop

\ WHILE

"{" printf 
0 
[ $list len != ]
[
	$list over geth printf
	1 +
	[ $list len != ] [ "-"printf ] if
] while
"}\n" print

drop
