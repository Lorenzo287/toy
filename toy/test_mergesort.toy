\ Test merge sort using native merge primitive
"toy/std/std.toy" load

'mergesort [
    [ small ]
    []
    [ splitmid ]
    [ [ < ] merge ]
    binrec
] def

"Testing mergesort:" print
[ 5 3 8 1 9 2 7 4 6 ] mergesort .s
len nip 9 == [ "len ok" print ] [ "len fail" print ] ifelse

"\nSorting large-ish range:" print
[] 20 [ rand 100 % append ] times
"Original: " printf .s
mergesort
"Sorted:   " printf .s
empty
