\ Complex File & String Processing Example: CSV Parser

"Step 1: Creating users.csv..." print
"users.csv" 
"name,age,city
Alice,30,New York
Bob,25,Los Angeles
Charlie,35,Chicago" writef

"users.csv" exists? [
    "Step 2: File exists. Reading and parsing content..." print cr
    
    "users.csv" readf 
    "\n" split \ obtain vector of strings (lines)
    
    \ Process lines: skip header, then split each data line
    uncons nip \ remove header, keep tail (the data rows)
    
    [ 
        trim
        dup len 0 > [ \ Only process non-empty lines
            "," split
            | record |
            " - " printf 
            $record 0 geth printf \ name
            " (" printf 
            $record 1 geth printf \ age
            ") lives in " printf 
            $record 2 geth print  \ city
        ] [ drop ] ifelse
    ] each

    cr "Step 3: Cleaning up..." print
    "users.csv" delf
    "Done." print
] [
    "FAILED: File users.csv was not found." print
] ifelse
