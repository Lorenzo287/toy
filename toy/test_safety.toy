"--- Testing Safety Predicates ---\n" printf

\ Testing word?
'dup word? [ "dup is defined\n" printf ] [ "dup is NOT defined\n" printf ] ifelse
'nonexistent word? [ "nonexistent is defined\n" printf ] [ "nonexistent is NOT defined\n" printf ] ifelse
"print" word? [ "string 'print' is defined\n" printf ] [ "string 'print' is NOT defined\n" printf ] ifelse

\ Testing var? (only checks locals/globals captures)
'dup word? [ "dup is defined globally\n" printf ] if
'dup var? [ "dup is a var (WRONG)\n" printf ] [ "dup is not a var (OK)\n" printf ] ifelse

[ | x | 'x var? [ "local x is defined\n" printf ] if ] 123 swap exec
'x var? [ "global x is defined (WRONG)\n" printf ] [ "global x is not defined\n" printf ] ifelse

\ Testing number?
10 number? [ "10 is a number\n" printf ] if
10.5 number? [ "10.5 is a number\n" printf ] if
"hello" number? [ "string is a number (WRONG)\n" printf ] [ "string is not a number\n" printf ] ifelse

\ Testing nan? and inf?
inf dup "inf = {}\n" printf
inf? [ "result is infinity\n" printf ] if

nan dup "nan = {}\n" printf
nan? [ "result is NaN\n" printf ] if

10.0 nan? [ "10.0 is NaN (WRONG)\n" printf ] [ "10.0 is not NaN\n" printf ] ifelse

"--- Done ---\n" printf
