\ Test string operations

"Testing concat:" print
"hello" " world" concat "hello world" == [ "ok" print ] [ "fail" print ] ifelse
[ 1 2 3 ] [ 4 5 6 ] concat 
dup len 6 == [ "len ok" print ] [ "len fail" print ] ifelse
0 geth 1 == [ "elem ok" print ] [ "elem fail" print ] ifelse

"\nTesting split:" print
"a,b,c" "," split
dup len 3 == [ "len ok" print ] [ "len fail" print ] ifelse
1 geth "b" == [ "elem ok" print ] [ "elem fail" print ] ifelse

"\nTesting join:" print
[ "a" "b" "c" ] "-" join "a-b-c" == [ "ok" print ] [ "fail" print ] ifelse

"\nTesting trim:" print
"  hello  " trim "hello" == [ "ok" print ] [ "fail" print ] ifelse

"\nTesting upper/lower:" print
"Hello" upper "HELLO" == [ "ok" print ] [ "fail" print ] ifelse
"Hello" lower "hello" == [ "ok" print ] [ "fail" print ] ifelse
