\ Test at and set-at
[ 10 20 30 ] |myVector|

\ Test at
$myVector 0 at print  \ Should print 10
$myVector 1 at print  \ Should print 20
$myVector 2 at print  \ Should print 30

\ Test set-at
$myVector 1 99 set-at |myVector|
$myVector 1 at print  \ Should print 99

\ Verify full vector
$myVector print
