{
    "name": "vscode-toyforth",
    "displayName": "Toy Support",
    "description": "Tree-sitter based syntax highlighting and LSP for Toy",
    "version": "0.2.0",
    "publisher": "Lorenzo287",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "activationEvents": [
        "onLanguage:toyforth"
    ],
    "main": "./extension.js",
    "contributes": {
        "languages": [
            {
                "id": "toyforth",
                "aliases": [
                    "Toy Forth",
                    "toyforth"
                ],
                "extensions": [
                    ".toy",
                    ".tf",
                    ".fth"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "toyforth",
                "scopeName": "source.toyforth",
                "path": "./syntaxes/toyforth.tmLanguage.json"
            }
        ]
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.0"
    }
}
