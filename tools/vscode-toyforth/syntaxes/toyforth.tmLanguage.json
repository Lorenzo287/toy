{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Toy Forth",
    "scopeName": "source.toyforth",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#functions" },
        { "include": "#keywords" },
        { "include": "#numbers" },
        { "include": "#words" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.block.toyforth",
                    "begin": "/\\*",
                    "end": "\\*/"
                },
                {
                    "name": "comment.line.backslash.toyforth",
                    "match": "\\\\.*$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.toyforth",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.toyforth",
                            "match": "\\\\(?:[nrt\"\\\\]|x[0-9a-fA-F]{2})"
                        },
                        {
                            "name": "invalid.illegal.escape.toyforth",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.toyforth",
                    "match": "'[a-zA-Z0-9_+\\-*/%<>=!.?]+"
                },
                {
                    "name": "entity.name.function.toyforth",
                    "match": "(?<=\\s|^)(dup|drop|swap|over|rot|swapd|nip|tuck|pick|roll|empty|pi|e|tau|print|printf|read-key|read-line|load|read-file|write-file|delete-file|read-lines|file-exists\\?|clear|type-of|bool\\?|int\\?|float\\?|string\\?|symbol\\?|vector\\?|list\\?|map\\?|set\\?|deque\\?|pqueue\\?|number\\?|sequence\\?|callable\\?|nan\\?|inf\\?|word\\?|var\\?|inf|nan|body|intern|name|words|see|doc|search-words|repr|at|set-at|>vector|>list|>string|>map|>set|>deque|>pqueue|contains\\?|index-of|unique|sort|has\\?|get|get-or|assoc|dissoc|keys|values|pairs|items|insert|remove|union|intersection|difference|symmetric-difference|subset\\?|proper-subset\\?|superset\\?|proper-superset\\?|disjoint\\?|push-front|push-back|pop-front|pop-back|pq-push|pq-peek|pq-pop|slice|take|skip|len|first|last|rest|uncons|cons|concat|reverse|join|trim|upper|lower|split-mid|range|char\\?|>char|char-code|letter\\?|digit\\?|alnum\\?|space\\?|upper\\?|lower\\?|punct\\?|rand|sleep|argc|argv|env\\?|get-env|set-env|pwd|shell|unix-time|local-time|utc-time|cpu-time|monotonic-ns|def|exit|\\.|\\.s|\\.S|empty\\?)(?=\\s|$)"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.toyforth",
                    "match": "\\b(if|ifelse|while|try|error|exec|i|app2|infra|cond|cleave|construct|replicate|times|dip|keep|bi|linrec|binrec|genrec|treerec|each|map|fold|filter|some|all|split|merge)\\b"
                },
                {
                    "name": "storage.type.toyforth",
                    "match": "(?<=\\s|^)(def|\\|)(?=\\s|$)"
                },
                {
                    "name": "keyword.operator.toyforth",
                    "match": "(?<=\\s|^)(\\+|\\-|\\*|/|%|==|!=|<|>|<=|>=|mod|abs|neg|max|min|sqrt|pow|exp|log|log10|sin|cos|tan|floor|ceil|round|pred|succ|square|cube|and|or|xor|not|shl|shr)(?=\\s|$)"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.toyforth",
                    "match": "(?<![a-zA-Z0-9_])[-+]?(?:\\d+(?:\\.\\d*)?|\\.\\d+)(?:[eE][-+]?\\d+)?(?![a-zA-Z0-9_.])"
                }
            ]
        },
        "words": {
            "patterns": [
                {
                    "name": "constant.language.toyforth",
                    "match": "\\b(nil|true|false|pi|e|tau|inf|nan)\\b"
                },
                {
                    "name": "variable.other.toyforth",
                    "match": "\\b\\w+\\b"
                }
            ]
        }
    }
}
