{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Toy Forth",
    "scopeName": "source.toyforth",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#functions" },
        { "include": "#keywords" },
        { "include": "#numbers" },
        { "include": "#words" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.backslash.toyforth",
                    "match": "\\\\.*$"
                },
                {
                    "name": "comment.block.parenthesis.toyforth",
                    "begin": "\\(",
                    "end": "\\)"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.toyforth",
                    "begin": "\"",
                    "end": "\""
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.toyforth",
                    "match": "'[a-zA-Z0-9_+\\-*/%<>=!.?]+"
                },
                {
                    "name": "entity.name.function.toyforth",
                    "match": "(?<=:\\s+)([a-zA-Z0-9_+\\-*/%<>=!.?]+)"
                },
                {
                    "name": "entity.name.function.toyforth",
                    "match": "(?<=\\s|^)(dup|drop|swap|over|rot|swapd|nip|tuck|pick|roll|empty|abs|neg|succ|pred|max|min|print|printf|cr|key|input|time|clear|page|words|see|load|geth|seth|len|first|rest|uncons|cons|append|concat|splitmid|range|rand|sleep|def|bye|exit|\\.|\\.s|empty\\?)(?=\\s|$)"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.toyforth",
                    "match": "\\b(if|ifelse|while|times|each|map|fold|exec|i|app2|dip|keep|bi|split|linrec|binrec)\\b"
                },
                {
                    "name": "storage.type.toyforth",
                    "match": "(?<=\\s|^)(:|def|{)(?=\\s|$)"
                },
                {
                    "name": "keyword.operator.toyforth",
                    "match": "(?<=\\s|^)(\\+|\\-|\\*|/|%|==|!=|<|>|<=|>=|mod)(?=\\s|$)"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.toyforth",
                    "match": "\\b\\d+(\\.\\d+)?\\b"
                }
            ]
        },
        "words": {
            "patterns": [
                {
                    "name": "constant.language.toyforth",
                    "match": "\\b(nil|true|false)\\b"
                },
                {
                    "name": "variable.other.toyforth",
                    "match": "\\b\\w+\\b"
                }
            ]
        }
    }
}
