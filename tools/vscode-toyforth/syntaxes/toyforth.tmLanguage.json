{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Toy Forth",
    "scopeName": "source.toyforth",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#functions" },
        { "include": "#keywords" },
        { "include": "#numbers" },
        { "include": "#words" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.backslash.toyforth",
                    "match": "\\\\.*$"
                },
                {
                    "name": "comment.block.parenthesis.toyforth",
                    "begin": "\\(",
                    "end": "\\)"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.toyforth",
                    "begin": "\"",
                    "end": "\""
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.toyforth",
                    "match": "'[a-zA-Z0-9_+\\-*/%<>=!.?]+"
                },
                {
                    "name": "entity.name.function.toyforth",
                    "match": "(?<=:\\s+)([a-zA-Z0-9_+\\-*/%<>=!.?]+)"
                },
                {
                    "name": "entity.name.function.toyforth",
                    "match": "(?<=\\s|^)(dup|drop|swap|over|rot|swapd|nip|tuck|pick|roll|empty|pi|e|tau|print|printf|cr|key|input|load|readf|writef|delf|readl|exists\\?|clear|page|typeof|bool\\?|int\\?|float\\?|str\\?|symbol\\?|list\\?|number\\?|sequence\\?|callable\\?|nan\\?|inf\\?|word\\?|var\\?|inf|nan|body|intern|name|words|see|geth|seth|slice|take|dropn|len|first|rest|uncons|cons|append|concat|reverse|join|trim|upper|lower|splitmid|range|char\\?|letter\\?|digit\\?|alnum\\?|space\\?|upper\\?|lower\\?|punct\\?|rand|sleep|argc|argv|env\\?|getenv|setenv|pwd|shell|time|clock|def|bye|exit|\\.|\\.s|\\.S|empty\\?)(?=\\s|$)"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.toyforth",
                    "match": "\\b(if|ifelse|while|try|error|exec|i|app2|infra|cond|cleave|construct|replicate|times|dip|keep|bi|linrec|binrec|genrec|treerec|each|map|fold|filter|some|all|split|merge)\\b"
                },
                {
                    "name": "storage.type.toyforth",
                    "match": "(?<=\\s|^)(:|def|{)(?=\\s|$)"
                },
                {
                    "name": "keyword.operator.toyforth",
                    "match": "(?<=\\s|^)(\\+|\\-|\\*|/|%|==|!=|<|>|<=|>=|mod|abs|neg|max|min|sqrt|pow|exp|log|log10|sin|cos|tan|floor|ceil|round|pred|succ|square|cube|and|or|xor|not|shl|shr)(?=\\s|$)"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.toyforth",
                    "match": "\\b\\d+(\\.\\d+)?\\b"
                }
            ]
        },
        "words": {
            "patterns": [
                {
                    "name": "constant.language.toyforth",
                    "match": "\\b(nil|true|false|pi|e|tau|inf|nan)\\b"
                },
                {
                    "name": "variable.other.toyforth",
                    "match": "\\b\\w+\\b"
                }
            ]
        }
    }
}
