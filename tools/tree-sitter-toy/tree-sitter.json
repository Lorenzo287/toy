{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "toy",
      "camelcase": "Toy",
      "title": "Toy",
      "scope": "source.toy",
      "file-types": [
        ".toy",
        ".tf",
        ".fth"
      ],
      "injection-regex": "^toy$",
      "class-name": "TreeSitterToy"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Toy grammar for tree-sitter",
    "authors": [
      {
        "name": "Lorenzo287",
        "url": ""
      }
    ]
  },
  "bindings": {
    "c": false,
    "go": false,
    "java": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
